# Voorbeeld — commit dit bestand, nooit .env
# Verplicht: cp .env.example .env vóór docker compose (geen fallbacks in docker-compose.yml)

# PostgreSQL (alleen comm-module; OpenMRS distro heeft eigen MariaDB)
POSTGRES_DB=comm_module
POSTGRES_USER=comm_user
POSTGRES_PASSWORD=changeme

# RabbitMQ
RABBITMQ_DEFAULT_USER=commuser
RABBITMQ_DEFAULT_PASS=changeme

# Communicatiemodule — DB/Rabbit moeten overeenkomen met bovenstaande rollen
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/comm_module
SPRING_DATASOURCE_USERNAME=comm_user
SPRING_DATASOURCE_PASSWORD=changeme
SPRING_RABBITMQ_HOST=rabbitmq
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=commuser
SPRING_RABBITMQ_PASSWORD=changeme

# OpenMRS 3 Reference Application (aparte docker compose, host poort 80)
# SPA afspraken: http://localhost/openmrs/spa/home/appointments
# Distro heeft geen FHIR2 Appointment — poll via MariaDB (patient_appointment):
OPENMRS_DATASOURCE_URL=jdbc:mariadb://host.docker.internal:3307/openmrs
OPENMRS_DATASOURCE_USERNAME=openmrs
OPENMRS_DATASOURCE_PASSWORD=openmrs
OPENMRS_SCHEDULING_SOURCE=patient-appointment
OPENMRS_FHIR_POLL_MODE=jdbc
OPENMRS_FHIR_ORGANISATION_ID=default
# OPENMRS_FHIR_SERVER_URL=   (leeg bij jdbc-poll)
OPENMRS_FHIR_USERNAME=admin
OPENMRS_FHIR_PASSWORD=Admin123
# OPENMRS_FHIR_POLL_INTERVAL_MINUTES=1
OPENMRS_FHIR_APPOINTMENT_POLL_SINCE_DAYS=30

# DBeaver: localhost:3307, database openmrs, user openmrs / openmrs (zie distro .env)

# Geen legacy JDBC-sync naar Postgres
OPENMRS_SCHEDULING_FHIR_SYNC_ENABLED=false
OPENMRS_SCHEDULING_FHIR_SYNC_INTERVAL_MINUTES=1
OPENMRS_SCHEDULING_SYNC_ZONE=Europe/Amsterdam
OPENMRS_SCHEDULING_SYNC_FALLBACK_PHONE=+31612345678

# Notificatie-scheduler
# COMM_NOTIFICATION_SCHEDULER_ENABLED=true
# COMM_NOTIFICATION_SCHEDULER_CHECK_INTERVAL_MINUTES=1
COMM_NOTIFICATION_REMINDER_LEAD_HOURS=24
COMM_NOTIFICATION_REMINDER_1_LEAD_HOURS=1
COMM_NOTIFICATION_REMINDER_WINDOW_MINUTES=60
# COMM_NOTIFICATION_REMINDER_ZONE=Europe/Amsterdam

# OpenTelemetry OTLP (in Docker: service otel-collector)
MANAGEMENT_OPENTELEMETRY_TRACING_EXPORT_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces

# Grafana UI
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# Encryptiesleutel voor gevoelige gegevens
APP_ENCRYPTION_KEY=change-me-use-32-byte-key-here!!
