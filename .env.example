# Voorbeeld — commit dit bestand, nooit .env
# Verplicht: cp .env.example .env vóór docker compose (geen fallbacks in docker-compose.yml)

# PostgreSQL (OpenMRS + comm-module datasource)
POSTGRES_DB=openmrs
POSTGRES_USER=openmrs_user
POSTGRES_PASSWORD=changeme

# RabbitMQ
RABBITMQ_DEFAULT_USER=commuser
RABBITMQ_DEFAULT_PASS=changeme

# OpenMRS admin (referentie-image)
OMRS_ADMIN_USER_PASSWORD=changeme

# Communicatiemodule — DB/Rabbit moeten overeenkomen met bovenstaande rollen
# Lokaal Docker: vaak zonder TLS. Prod: bijv. ...?sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/openmrs
SPRING_DATASOURCE_USERNAME=openmrs_user
SPRING_DATASOURCE_PASSWORD=changeme
SPRING_RABBITMQ_HOST=rabbitmq
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=commuser
SPRING_RABBITMQ_PASSWORD=changeme
OPENMRS_URL=http://openmrs:8080/openmrs

# FHIR R5 (HL7 Appointment + Patient) — standalone HAPI-server in Docker, niet OpenMRS FHIR2
OPENMRS_FHIR_SERVER_URL=http://fhir-r5:8080/fhir
# Leeg laten voor HAPI zonder auth; alleen vullen bij een beveiligde FHIR-server
OPENMRS_FHIR_USERNAME=
OPENMRS_FHIR_PASSWORD=
# Tenant-key voor polled_appointment.organisation_id (default: default)
OPENMRS_FHIR_ORGANISATION_ID=default
# Optioneel: poll-interval minuten / Appointment zoekvenster / retry (zie application.properties defaults)
# OPENMRS_FHIR_POLL_INTERVAL_MINUTES=5
OPENMRS_FHIR_APPOINTMENT_POLL_SINCE_DAYS=30
# OPENMRS_FHIR_RETRY_MAX_ATTEMPTS=3

# Notificatie-scheduler (docker-compose geeft deze door aan comm-module)
# COMM_NOTIFICATION_SCHEDULER_ENABLED=true
# COMM_NOTIFICATION_SCHEDULER_CHECK_INTERVAL_MINUTES=1
COMM_NOTIFICATION_REMINDER_LEAD_HOURS=24
COMM_NOTIFICATION_REMINDER_WINDOW_MINUTES=60
# COMM_NOTIFICATION_REMINDER_ZONE=Europe/Amsterdam

# OpenTelemetry OTLP (in Docker: service otel-collector)
MANAGEMENT_OPENTELEMETRY_TRACING_EXPORT_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
# Metrics: Prometheus scrape; OTLP metrics export staat uit in application.properties

# Grafana UI
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# Encryptiesleutel voor gevoelige gegevens 
APP_ENCRYPTION_KEY=change-me-use-32-byte-key-here!!