# Voorbeeld zonder echte secrets — commit dit bestand, nooit .env
# Gebruik: cp .env.example .env en vul waarden in (lokaal of team-afspraken)
# Geen .env? Dan gebruikt Docker Compose de defaults in docker-compose.yml (${VAR:-default})

# PostgreSQL (OpenMRS + comm-module datasource)
POSTGRES_DB=openmrs
POSTGRES_USER=openmrs_user
POSTGRES_PASSWORD=changeme

# RabbitMQ
RABBITMQ_DEFAULT_USER=commuser
RABBITMQ_DEFAULT_PASS=changeme

# OpenMRS admin (referentie-image)
OMRS_ADMIN_USER_PASSWORD=changeme

# Communicatiemodule — DB/Rabbit moeten overeenkomen met bovenstaande rollen
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/openmrs
SPRING_DATASOURCE_USERNAME=openmrs_user
SPRING_DATASOURCE_PASSWORD=changeme
SPRING_RABBITMQ_HOST=rabbitmq
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=commuser
SPRING_RABBITMQ_PASSWORD=changeme
OPENMRS_URL=http://openmrs:8080/openmrs
